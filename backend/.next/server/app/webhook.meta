{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/webhook/layout,_N_T_/webhook/page,_N_T_/webhook"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/webhook/__PAGE__",
    "/webhook",
    "/_index",
    "/_head"
  ]
}